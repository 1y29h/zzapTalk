# =========================
# DEPENDENCIES
# =========================
/node_modules

# =========================
# BUILD / OUTPUT
# =========================
dist-ssr/
web-build/
coverage/

# =========================
# EXPO / METRO
# =========================
.expo/
expo-env.d.ts
.metro-health-check*

# =========================
