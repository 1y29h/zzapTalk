# =========================
ios/
android/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# =========================
# LOGS
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# ENV / LOCAL CONFIG  (🚨 keep secrets out of git)
# =========================
.env
.env.local
.env.*.local
.env*.local
*.local

# =========================
# IDE / OS
# =========================
.vscode/
.idea/
.DS_Store
*.pem

# =========================
# TYPESCRIPT
# =========================
*.tsbuildinfo

